---
// Emits a Schema.org JSON-LD block on the page.
// Pass either a single object or an array via the `data` prop; each top-level
// item is rendered as its own ld+json element. The Layout already emits
// Organization + WebSite on every page, so this component is for page-specific
// schema (BreadcrumbList, FAQPage, SoftwareApplication, etc.).

interface Props {
  data: unknown;
}

const { data } = Astro.props;

// Normalize to an array so we always emit one element per top-level object.
// Filter out falsy entries so callers can do `data={cond && schema}`.
const items: unknown[] = (Array.isArray(data) ? data : [data]).filter(Boolean);

// Escape closing tags so a JSON string can't break out of the host element.
// JSON.stringify already handles the rest safely.
function safeStringify(value: unknown): string {
  return JSON.stringify(value).replace(/<\/(script)/gi, "<\\/$1");
}
---

{
  items.map((item) => (
    <script
      type="application/ld+json"
      set:html={safeStringify(item)}
    />
  ))
}
