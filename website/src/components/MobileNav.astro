---
// Mobile drawer triggered by the hamburger button in Nav.astro.
// Pure HTML/CSS — uses :target pattern for openness so we don't need JS.
// The opening element is a button-as-anchor that flips the URL hash.
interface Props {
  links: { href: string; label: string; external?: boolean }[];
}
const { links } = Astro.props;
---

<aside
  id="mobile-nav"
  class="mobile-drawer fixed inset-0 z-50 hidden flex-col"
  aria-label="Mobile navigation"
>
  <!-- Backdrop -->
  <a
    href="#"
    class="absolute inset-0"
    aria-label="Close menu"
    style="background: rgba(0,0,0,0.55); backdrop-filter: blur(4px);"
  ></a>

  <!-- Drawer -->
  <div
    class="relative ml-auto flex h-full w-[88%] max-w-sm flex-col"
    style="background: var(--color-panel-solid); border-left: 1px solid var(--gray-a4);"
  >
    <div
      class="flex h-16 items-center justify-between px-5"
      style="border-bottom: 1px solid var(--gray-a4);"
    >
      <span
        class="text-[11px] font-bold uppercase tracking-wider"
        style="color: var(--gray-11);">Menu</span
      >
      <a
        href="#"
        aria-label="Close menu"
        class="flex h-8 w-8 items-center justify-center rounded-md"
        style="color: var(--gray-11);"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </a>
    </div>

    <nav class="flex-1 overflow-y-auto px-2 py-4">
      <ul class="space-y-0.5" role="list">
        {
          links.map((l) => (
            <li>
              <a
                href={l.href}
                class="flex items-center justify-between rounded-md px-3 py-2.5 text-[15px] font-medium"
                style="color: var(--gray-12);"
                target={l.external ? "_blank" : undefined}
                rel={l.external ? "noopener" : undefined}
              >
                {l.label}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  style="color: var(--gray-9);"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div
      class="px-5 py-5"
      style="border-top: 1px solid var(--gray-a4); background: var(--gray-2);"
    >
      <a
        href="/access"
        class="btn-primary w-full"
        style="height: 44px;"
      >
        Try free
      </a>
    </div>
  </div>
</aside>

<style>
  .mobile-drawer:target {
    display: flex;
  }
</style>
