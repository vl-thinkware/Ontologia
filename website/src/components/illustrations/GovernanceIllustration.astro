---
// Governance: change history timeline with attributed events, tags, and revert.
---

<div
  class="relative mx-auto w-full max-w-[480px]"
  role="img"
  aria-label="Change history timeline with attributed events and a tag marker."
>
  <svg
    viewBox="0 0 480 420"
    xmlns="http://www.w3.org/2000/svg"
    class="h-auto w-full"
    role="img"
  >
    <title>Governance change history timeline with tags</title>
    <desc>An ontology change history timeline showing attributed events, version tags, and a revert affordance.</desc>
    <defs>
      <linearGradient id="govCard" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="var(--color-panel-solid)"></stop>
        <stop offset="1" stop-color="var(--gray-2)"></stop>
      </linearGradient>
      <filter id="govShadow" x="-10%" y="-10%" width="120%" height="120%">
        <feDropShadow
          dx="0"
          dy="3"
          stdDeviation="6"
          flood-color="rgb(15 23 42)"
          flood-opacity="0.07"></feDropShadow>
      </filter>
    </defs>

    <pattern
      id="govDots"
      x="0"
      y="0"
      width="20"
      height="20"
      patternUnits="userSpaceOnUse"
    >
      <circle cx="1" cy="1" r="1" fill="var(--gray-a4)"></circle>
    </pattern>
    <rect width="480" height="420" fill="url(#govDots)" opacity="0.4"></rect>

    <g filter="url(#govShadow)">
      <rect
        x="30"
        y="30"
        width="420"
        height="360"
        rx="12"
        fill="url(#govCard)"
        stroke="var(--gray-a5)"></rect>

      <!-- Header -->
      <text
        x="50"
        y="60"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="600"
        fill="var(--gray-11)"
        letter-spacing="0.12em">CHANGE HISTORY</text
      >
      <text
        x="50"
        y="80"
        font-family="Inter, sans-serif"
        font-size="14"
        font-weight="700"
        fill="var(--gray-12)">Last 24 hours</text
      >

      <!-- Tag chip top-right -->
      <rect
        x="350"
        y="56"
        width="84"
        height="24"
        rx="12"
        fill="var(--violet-3)"
        stroke="var(--violet-7)"></rect>
      <g transform="translate(360,68)">
        <path
          d="M 4 0 L 12 0 L 18 6 L 12 12 L 4 12 Z"
          fill="var(--violet-9)"
          transform="translate(0,-4)"></path>
      </g>
      <text
        x="396"
        y="72"
        text-anchor="middle"
        font-family="ui-monospace, monospace"
        font-size="10"
        font-weight="600"
        fill="var(--violet-11)">v1.3</text
      >

      <!-- Timeline rail -->
      <line
        x1="74"
        y1="110"
        x2="74"
        y2="370"
        stroke="var(--gray-a4)"
        stroke-width="2"></line>

      <!-- Event 1: tag (most recent) -->
      <circle cx="74" cy="120" r="7" fill="var(--violet-9)"></circle>
      <rect
        x="92"
        y="106"
        width="346"
        height="44"
        rx="8"
        fill="var(--violet-2)"
        stroke="var(--violet-a5)"></rect>
      <text
        x="106"
        y="124"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="700"
        fill="var(--gray-12)">Tagged v1.3</text
      >
      <text
        x="106"
        y="140"
        font-family="Inter, sans-serif"
        font-size="10"
        fill="var(--gray-11)">@valentin · 2 minutes ago</text
      >

      <!-- Event 2: revert -->
      <circle cx="74" cy="170" r="6" fill="var(--amber-9)"></circle>
      <rect
        x="92"
        y="158"
        width="346"
        height="44"
        rx="8"
        fill="var(--amber-2)"
        stroke="var(--amber-a5)"></rect>
      <text
        x="106"
        y="176"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="700"
        fill="var(--gray-12)">Reverted ce_087</text
      >
      <text
        x="106"
        y="192"
        font-family="Inter, sans-serif"
        font-size="10"
        fill="var(--gray-11)"
        >@alexandre · 14 min ago · "wrong domain on poweredBy"</text
      >

      <!-- Event 3: update -->
      <circle cx="74" cy="220" r="5" fill="var(--sky-9)"></circle>
      <rect
        x="92"
        y="208"
        width="346"
        height="44"
        rx="8"
        fill="url(#govCard)"
        stroke="var(--gray-a4)"></rect>
      <text
        x="106"
        y="226"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="700"
        fill="var(--gray-12)">Updated "Toyota Camry"</text
      >
      <text
        x="106"
        y="242"
        font-family="Inter, sans-serif"
        font-size="10"
        fill="var(--gray-11)">@valentin · 32 min ago · prefLabel</text
      >

      <!-- Event 4: deprecate -->
      <circle cx="74" cy="270" r="5" fill="var(--ruby-9)"></circle>
      <rect
        x="92"
        y="258"
        width="346"
        height="44"
        rx="8"
        fill="url(#govCard)"
        stroke="var(--gray-a4)"></rect>
      <text
        x="106"
        y="276"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="700"
        fill="var(--gray-12)">Deprecated "Diesel"</text
      >
      <text
        x="106"
        y="292"
        font-family="Inter, sans-serif"
        font-size="10"
        fill="var(--gray-11)">@alexandre · 1 hour ago · → "Diesel (EU6)"</text
      >

      <!-- Event 5: create -->
      <circle cx="74" cy="320" r="5" fill="var(--green-9)"></circle>
      <rect
        x="92"
        y="308"
        width="346"
        height="44"
        rx="8"
        fill="url(#govCard)"
        stroke="var(--gray-a4)"></rect>
      <text
        x="106"
        y="326"
        font-family="Inter, sans-serif"
        font-size="11"
        font-weight="700"
        fill="var(--gray-12)">Created "Hybrid (PHEV)"</text
      >
      <text
        x="106"
        y="342"
        font-family="Inter, sans-serif"
        font-size="10"
        fill="var(--gray-11)">@valentin · 3 hours ago</text
      >
    </g>
  </svg>
</div>
