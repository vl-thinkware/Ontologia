---
// Schema view illustration: T-Box ER diagram with connected class boxes.
// Layout: clean 2×2 grid so edge labels sit in genuine empty space — never
// behind a card.
---

<div
  class="relative mx-auto w-full max-w-[560px]"
  role="img"
  aria-label="Diagram of an ontology schema with connected concept classes."
>
  <svg
    viewBox="0 0 560 420"
    xmlns="http://www.w3.org/2000/svg"
    class="h-auto w-full"
    role="img"
  >
    <title>Ontology schema canvas — connected concept classes</title>
    <desc>An ER-style diagram of a T-Box: concept-class boxes linked by typed relations on a clean grid.</desc>
    <defs>
      <linearGradient id="schemaCard" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="var(--color-panel-solid)"></stop>
        <stop offset="1" stop-color="var(--gray-2)"></stop>
      </linearGradient>
      <filter id="schemaShadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow
          dx="0"
          dy="3"
          stdDeviation="6"
          flood-color="rgb(15 23 42)"
          flood-opacity="0.18"
        ></feDropShadow>
      </filter>
      <marker
        id="arrow"
        viewBox="0 0 10 10"
        refX="9"
        refY="5"
        markerWidth="6"
        markerHeight="6"
        orient="auto-start-reverse"
      >
        <path d="M 0 0 L 10 5 L 0 10 z" fill="var(--violet-9)"></path>
      </marker>
    </defs>

    <!-- Background grid dots -->
    <pattern
      id="schemaDots"
      x="0"
      y="0"
      width="20"
      height="20"
      patternUnits="userSpaceOnUse"
    >
      <circle cx="1" cy="1" r="1" fill="var(--gray-a4)"></circle>
    </pattern>
    <rect width="560" height="420" fill="url(#schemaDots)" opacity="0.45"
    ></rect>

    <!--
      Layout (2 × 2):
        Manufacturer (top-left)        Model (top-right)
              ↓ hasBodyStyle (diagonal)        ↓ poweredBy (vertical)
        BodyStyle (bottom-left)        Engine (bottom-right)

      Manufacturer → Model: horizontal "manufactures"
    -->

    <!-- Edges first so cards sit on top -->
    <g
      stroke="var(--violet-9)"
      stroke-width="2.25"
      fill="none"
      stroke-linecap="round"
    >
      <!-- Manufacturer → Model (horizontal, top row) -->
      <path d="M 220 110 L 350 110" marker-end="url(#arrow)"></path>

      <!-- Model → Engine (vertical, right column) -->
      <path d="M 440 200 L 440 250" marker-end="url(#arrow)"></path>

      <!-- Model → BodyStyle (diagonal, top-right to bottom-left) -->
      <path d="M 360 180 L 220 260" marker-end="url(#arrow)"></path>
    </g>

    <!-- Edge labels — positioned in empty space, sized to be readable -->
    <g
      font-family="ui-monospace, monospace"
      font-size="10.5"
      font-weight="600"
    >
      <!-- "manufactures" — between Manufacturer and Model on top row -->
      <rect
        x="240"
        y="98"
        width="92"
        height="22"
        rx="4"
        fill="var(--violet-3)"
        stroke="var(--violet-a6)"
        stroke-width="1"></rect>
      <text x="286" y="113" text-anchor="middle" fill="var(--violet-11)"
        >manufactures</text
      >

      <!-- "poweredBy" — between Model bottom and Engine top, fully clear -->
      <rect
        x="403"
        y="213"
        width="74"
        height="22"
        rx="4"
        fill="var(--violet-3)"
        stroke="var(--violet-a6)"
        stroke-width="1"></rect>
      <text x="440" y="228" text-anchor="middle" fill="var(--violet-11)"
        >poweredBy</text
      >

      <!-- "hasBodyStyle" — on the diagonal, mid-arrow -->
      <rect
        x="246"
        y="208"
        width="86"
        height="22"
        rx="4"
        fill="var(--violet-3)"
        stroke="var(--violet-a6)"
        stroke-width="1"></rect>
      <text x="289" y="223" text-anchor="middle" fill="var(--violet-11)"
        >hasBodyStyle</text
      >
    </g>

    <!-- Class card 1: Manufacturer (top-left) -->
    <g filter="url(#schemaShadow)">
      <rect
        x="40"
        y="50"
        width="160"
        height="120"
        rx="12"
        fill="url(#schemaCard)"
        stroke="var(--violet-7)"
        stroke-width="1.5"></rect>
      <rect x="40" y="50" width="160" height="6" rx="3" fill="var(--violet-9)"
      ></rect>
      <text
        x="56"
        y="80"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="600"
        fill="var(--violet-11)"
        letter-spacing="0.12em">CLASS</text
      >
      <text
        x="56"
        y="100"
        font-family="Inter, sans-serif"
        font-size="14"
        font-weight="700"
        fill="var(--gray-12)">Manufacturer</text
      >
      <line
        x1="56"
        y1="110"
        x2="184"
        y2="110"
        stroke="var(--gray-a4)"
        stroke-width="1"></line>
      <g
        font-family="ui-monospace, monospace"
        font-size="10"
        fill="var(--gray-11)"
      >
        <text x="56" y="128">name : string</text>
        <text x="56" y="142">country : reference</text>
        <text x="56" y="156">founded : date</text>
      </g>
    </g>

    <!-- Class card 2: Model (top-right) -->
    <g filter="url(#schemaShadow)">
      <rect
        x="360"
        y="60"
        width="160"
        height="140"
        rx="12"
        fill="url(#schemaCard)"
        stroke="var(--violet-7)"
        stroke-width="1.5"></rect>
      <rect x="360" y="60" width="160" height="6" rx="3" fill="var(--violet-9)"
      ></rect>
      <text
        x="376"
        y="90"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="600"
        fill="var(--violet-11)"
        letter-spacing="0.12em">CLASS</text
      >
      <text
        x="376"
        y="110"
        font-family="Inter, sans-serif"
        font-size="14"
        font-weight="700"
        fill="var(--gray-12)">Model</text
      >
      <line
        x1="376"
        y1="120"
        x2="504"
        y2="120"
        stroke="var(--gray-a4)"
        stroke-width="1"></line>
      <g
        font-family="ui-monospace, monospace"
        font-size="10"
        fill="var(--gray-11)"
      >
        <text x="376" y="138">name : string</text>
        <text x="376" y="152">year : number</text>
        <text x="376" y="166">msrp : money</text>
        <text x="376" y="180">trim : enum</text>
      </g>
    </g>

    <!-- Class card 3: BodyStyle (bottom-left) -->
    <g filter="url(#schemaShadow)">
      <rect
        x="40"
        y="260"
        width="160"
        height="100"
        rx="12"
        fill="url(#schemaCard)"
        stroke="var(--sky-7)"
        stroke-width="1.5"></rect>
      <rect x="40" y="260" width="160" height="6" rx="3" fill="var(--sky-9)"
      ></rect>
      <text
        x="56"
        y="290"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="600"
        fill="var(--sky-11)"
        letter-spacing="0.12em">CLASS</text
      >
      <text
        x="56"
        y="310"
        font-family="Inter, sans-serif"
        font-size="14"
        font-weight="700"
        fill="var(--gray-12)">BodyStyle</text
      >
      <line
        x1="56"
        y1="320"
        x2="184"
        y2="320"
        stroke="var(--gray-a4)"
        stroke-width="1"></line>
      <text
        x="56"
        y="340"
        font-family="ui-monospace, monospace"
        font-size="10"
        fill="var(--gray-11)">+ 3 attributes</text
      >
    </g>

    <!-- Class card 4: Engine (bottom-right) -->
    <g filter="url(#schemaShadow)">
      <rect
        x="360"
        y="260"
        width="160"
        height="100"
        rx="12"
        fill="url(#schemaCard)"
        stroke="var(--green-7)"
        stroke-width="1.5"></rect>
      <rect x="360" y="260" width="160" height="6" rx="3" fill="var(--green-9)"
      ></rect>
      <text
        x="376"
        y="290"
        font-family="Inter, sans-serif"
        font-size="9"
        font-weight="600"
        fill="var(--green-11)"
        letter-spacing="0.12em">CLASS</text
      >
      <text
        x="376"
        y="310"
        font-family="Inter, sans-serif"
        font-size="14"
        font-weight="700"
        fill="var(--gray-12)">Engine</text
      >
      <line
        x1="376"
        y1="320"
        x2="504"
        y2="320"
        stroke="var(--gray-a4)"
        stroke-width="1"></line>
      <text
        x="376"
        y="340"
        font-family="ui-monospace, monospace"
        font-size="10"
        fill="var(--gray-11)">+ 5 attributes</text
      >
    </g>
  </svg>
</div>
