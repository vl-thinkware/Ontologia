---
// One feature block on a product detail page: heading + body on one side,
// illustration / screenshot / code slot on the other. Alternates left/right.
interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  reverse?: boolean;
  bullets?: string[];
}

const { eyebrow, title, body, reverse = false, bullets = [] } = Astro.props;
---

<section class="py-16 md:py-24">
  <div class="container-page">
    <div
      class={`grid grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-16 ${
        reverse ? "md:[&>:first-child]:order-2" : ""
      }`}
    >
      <div data-fade-up>
        {eyebrow && <p class="text-eyebrow">{eyebrow}</p>}
        <h2
          class="text-headline mt-2"
          style="font-size: clamp(1.5rem, 1rem + 1.5vw, 2rem);"
        >
          {title}
        </h2>
        <p
          class="mt-4 max-w-md text-[15.5px] leading-relaxed"
          style="color: var(--gray-11);"
        >
          {body}
        </p>
        {
          bullets.length > 0 && (
            <ul class="mt-5 space-y-2.5" role="list">
              {bullets.map((b) => (
                <li class="flex items-start gap-2.5 text-[14px]" style="color: var(--gray-12);">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--green-9)"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    style="margin-top: 4px; flex-shrink: 0;"
                  >
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          )
        }
      </div>
      <div data-fade-up data-delay="1">
        <slot />
      </div>
    </div>
  </div>
</section>
