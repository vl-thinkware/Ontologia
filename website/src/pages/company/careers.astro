---
import ComingSoon from "../../components/ComingSoon.astro";
---

<ComingSoon
  title="Careers"
  description="Roles open at Semlify. We're a tiny team — every hire matters."
  current="/company/careers"
  eyebrow="We're hiring soon"
  whenLabel="First roles open in 2026"
  body="We're a two-person founding team. The first hire is planned for late 2026 once we cross our first revenue milestones. If you're an exceptional engineer or designer who builds with care, we'd love to hear from you anyway — early conversations beat late introductions."
  bullets={[
    "Bootstrapped, profitable, in no rush to over-hire",
    "Remote-friendly with quarterly meetups in Paris",
    "Equity from day one for everyone we hire",
    "Generous PTO and proper work-life boundaries",
  ]}
  ctaTitle="Want to be considered when we open?"
  ctaSubtitle="Send us your work — code, designs, writing — at hello@semlify.com."
/>
