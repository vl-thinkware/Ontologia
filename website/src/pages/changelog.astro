---
import ComingSoon from "../components/ComingSoon.astro";
---

<ComingSoon
  title="Changelog"
  description="The shipping log for Semlify — feature releases, fixes, and infra notes."
  current="/changelog"
  eyebrow="Coming with GA"
  whenLabel="First entries land at GA · Q3 2026"
  body="Every weekly release will appear here, dated and linked back to the docs page that explains what changed and why. The format is borrowed from Linear and Vercel — short, accurate, no fluff."
  bullets={[
    "One entry per release · semver tagged",
    "Inline screenshots for visible UI changes",
    "Links to the relevant docs page",
    "RSS feed for readers, JSON for integrations",
  ]}
/>
